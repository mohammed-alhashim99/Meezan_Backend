# ── Meezan Backend — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the values (never commit .env)

# Django secret key — generate a strong random key for production
SECRET_KEY=django-insecure-dev-key-change-in-production

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts
# Local: localhost,127.0.0.1
# Production: meezan-backend.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of allowed CORS origins (added to the hardcoded dev defaults)
# Production: add your Vercel URL, e.g. https://meezan.vercel.app
CORS_ALLOWED_ORIGINS=

# Anthropic API key — required for categorisation and insights
ANTHROPIC_API_KEY=sk-ant-...
